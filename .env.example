NODE_ENV=development

# Core settings (required)
AUTH_URL=http://localhost:3000 # The URL where Norish is reachable
DATABASE_URL=postgres://postgres:norish@localhost:5432/norish
MASTER_KEY=<32-byte-base64-key>    # Generate with: openssl rand -base64 32
CHROME_WS_ENDPOINT=ws://localhost:3003  # Playwright CDP WebSocket endpoint for scraping
REDIS_URL=redis://localhost:6379   # Redis connection URL for real-time events and job queues
NEXT_PUBLIC_LOG_LEVEL=info         # trace, debug, info, warn, error, fatal (default: info in prod, debug in dev)

# Optional
UPLOADS_DIR=/app/uploads                # Defaults to ./.runtime/uploads in development, /app/uploads in production
# YT_DLP_BIN_DIR=/app/bin               # Defaults to ./.runtime/bin in development, /app/bin in production
# PARSER_API_TIMEOUT_MS=15000           # Timeout for parser API calls in milliseconds
# LEGACY_RECIPE_PARSER_ROLLBACK=false  # Set true to re-enable the deprecated legacy parser path
# NEXT_PUBLIC_LOG_LEVEL=info            # trace, debug, info, warn, error, fatal
# TRUSTED_ORIGINS=http://192.168.1.100:3000,https://norish.example.com  # Additional trusted origins, comma separated. Useful when behind a proxy or using multiple domains.

# Internationalization
# DEFAULT_LOCALE=en                # Instance default locale (must match a supported locale, defaults to 'en')
# ENABLED_LOCALES=en,de,nl         # Comma-separated locale list (empty = all locales enabled)


# ─────────────────────────────────────────────────────────────────────────
# FIRST USER SETUP
# ─────────────────────────────────────────────────────────────────────────
# On first startup, configure ONE auth provider below to create your admin account.
# After first login, use Settings => Admin to configure additional providers,
# AI settings, video parsing, and all other options.

# Option 1=Password auth - basic auth with email/password
# If not set defaults to disabled if OIDC or OAuth is configured.
# Defaults to true if no other auth providers are configured.
#PASSWORD_AUTH_ENABLED=false # Enable/disable password auth default: false

# Option 2=OIDC (Authentik, Keycloak, PocketID, etc.)
# OIDC_NAME=NoraId
# OIDC_ISSUER=https://nora.example.com
# OIDC_CLIENT_ID=<client-id>
# OIDC_CLIENT_SECRET=<client-secret>
# OIDC_WELLKNOWN=https://auth.example.com/.well-known/openid-configuration
# Wellknown is optional: By default the wellknown URL is derived from the issuer by appending /.well-known/openid-configuration

# OIDC Claim Mapping (optional) - Auto-assign roles and households based on OIDC claims
# OIDC_CLAIM_MAPPING_ENABLED=false    # Enable claim-based role/household assignment (default: false, disabled for security)
# OIDC_SCOPES=groups                   # Additional scopes to request (comma-separated, e.g., "groups" for Keycloak)
# OIDC_GROUPS_CLAIM=groups             # Claim containing user groups (default: groups)
# OIDC_ADMIN_GROUP=norish_admin        # Group that grants server admin role (default: norish_admin)
# OIDC_HOUSEHOLD_GROUP_PREFIX=norish_household_  # Prefix for household groups (default: norish_household_)

# Option 3=GitHub OAuth (uncomment and remove OIDC above)
# GITHUB_CLIENT_ID=<github-client-id>
# GITHUB_CLIENT_SECRET=<github-client-secret>

# Option 4=Google OAuth (uncomment and remove OIDC above)
# GOOGLE_CLIENT_ID=<google-client-id>
# GOOGLE_CLIENT_SECRET=<google-client-secret>

# Option 5=WorkOS AuthKit (uncomment and remove OIDC above)
# Configured ONLY via env (config-as-code); WorkOS has no admin-UI panel.
# Wired as a FIRST-PARTY AuthKit provider against api.workos.com/user_management
# (authorize?provider=authkit + the authenticate token call). No AuthKit domain needed.
# Register the callback ${AUTH_URL}/api/auth/oauth2/callback/workos in the WorkOS dashboard.
# WORKOS_CLIENT_ID is the WorkOS Environment Client ID (client_.../project_...).
# WORKOS_API_KEY is the WorkOS API Key (sk_...), used as the OAuth client secret.
# Both are required to enable the provider.
# WORKOS_CLIENT_ID=<workos-client-id>
# WORKOS_API_KEY=<workos-api-key>

# ─────────────────────────────────────────────────────────────────────────
# SERVER ADMIN / OPERATOR ALLOWLIST (config-as-code — env is the source of truth)
# ─────────────────────────────────────────────────────────────────────────
# ADMIN_EMAILS is the SINGLE source of truth for who is a SERVER admin (operator):
# the user(s) who can reach Settings => Admin (AI config, video/transcription, auth
# providers). Comma-separated, CASE-INSENSITIVE, whitespace-trimmed.
#
# When SET it is AUTHORITATIVE and re-evaluated on EVERY login:
#   - only listed emails are server-admin; the FIRST person to sign up is a regular
#     user unless their email is listed;
#   - anyone previously auto-promoted (legacy first-user-owner) who is NOT listed is
#     DEMOTED to a regular user on their next login.
# When UNSET/empty, the legacy behavior is preserved (the first user to sign up
# becomes the server owner/admin) so existing self-host installs never lock out.
#
# This is the SERVER-level admin only — it does NOT affect per-cookbook/household
# ownership; regular users still own and admin their OWN cookbooks.
# ADMIN_EMAILS=admin@example.com,ops@example.com


# ─────────────────────────────────────────────────────────────────────────
# AI & TRANSCRIPTION (operator config — env is the SOURCE OF TRUTH)
# ─────────────────────────────────────────────────────────────────────────
# Unlike most settings (which can be set once via Settings → Admin), the AI provider
# and transcription credentials are re-seeded from these env vars on EVERY boot and
# OVERWRITE the database row. This is config-as-code for server-hosted deployments:
# the config survives a clean DB / relaunch with zero admin clicks. If you leave these
# unset, the admin-UI values (stored in the DB) remain authoritative — nothing changes
# for existing self-host installs.

# AI provider — enables recipe AI extraction / auto-tagging.
# AI_PROVIDER one of: openai, deepseek, anthropic, google, mistral, groq, perplexity,
#   azure, ollama, lm-studio, generic-openai. (Single key var: AI_API_KEY for ALL cloud
#   providers; local providers ollama/lm-studio/generic-openai use AI_ENDPOINT instead.)
# AI_ENABLED=true
# AI_PROVIDER=deepseek
# AI_MODEL=deepseek-chat
# AI_API_KEY=<your-ai-api-key>          # required for cloud providers (openai/deepseek/google/…)
# AI_ENDPOINT=http://ollama:11434       # required INSTEAD of AI_API_KEY for local providers
# AI_TEMPERATURE=1.0                    # 0.0–2.0 (default 1.0)
# AI_MAX_TOKENS=10000
# AI_TIMEOUT_MS=300000

# Video transcription (separate from the AI provider). Re-seeded on boot like AI above.
# TRANSCRIPTION_PROVIDER one of: openai, groq, azure, assemblyai, generic-openai, ollama, disabled.
# VIDEO_PARSING_ENABLED=true
# TRANSCRIPTION_PROVIDER=assemblyai
# TRANSCRIPTION_API_KEY=<your-transcription-api-key>   # required for cloud providers
# TRANSCRIPTION_ENDPOINT=http://ollama:11434           # required INSTEAD for local providers
# TRANSCRIPTION_MODEL=best
