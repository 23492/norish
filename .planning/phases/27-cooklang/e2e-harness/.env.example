# Copy to .env (gitignored) to run the REAL end-to-end against live DeepSeek.
# The harness reads DEEPSEEK_API_KEY from the environment / this .env ONLY.
# NEVER commit a real key. .env is gitignored.
DEEPSEEK_API_KEY=sk-your-real-deepseek-key-here
# Optional: point at a reachable Camoufox REST service (default docker host is
# camofox:9377, which is not reachable outside the stack -> harness falls back to
# a plain HTTP fetch and says so).
# CAMOFOX_URL=http://localhost:9377
