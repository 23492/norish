# norish-beta.knoppsmart.com — beta environment template (Phase 20 / D-11/D-12)
#
# Copy this file to /opt/norish/beta.env and fill in every value marked <REQUIRED>.
# This file is safe to commit — it contains NO real secrets, only placeholders.
#
# ISOLATION REQUIREMENTS:
#   - DATABASE_URL must point at norish-beta-db (the isolated beta Postgres), NEVER the live DB.
#   - MASTER_KEY MUST be a NEW key, distinct from live's key.
#     Reason: better-auth's encryption (used for OAuth tokens, session secrets, etc.) is
#     key-specific. Live's encrypted secrets are incompatible with a different key, and
#     reusing live's key on beta would expose live secrets to the beta environment
#     (T-20-06-KEY threat). Generate a fresh key: openssl rand -base64 32
#
# WorkOS callback for the beta domain:
#   Register https://norish-beta.knoppsmart.com/api/auth/oauth2/callback/workos
#   in the WorkOS dashboard → User Management → Redirects BEFORE starting the beta stack.
#
# Usage:
#   docker compose -f docker/docker-compose.beta.yml --env-file /opt/norish/beta.env up -d

# ── Core (required) ───────────────────────────────────────────────────────────

# The public URL of the beta app. Must match the Cloudflare ingress target.
AUTH_URL=https://norish-beta.knoppsmart.com

# Must include the beta domain. Add comma-separated extras if needed.
TRUSTED_ORIGINS=https://norish-beta.knoppsmart.com

# Beta DB connection — points at the isolated norish-beta-db container, NEVER the live DB.
# Format: postgres://postgres:<BETA_DB_PASSWORD>@norish-beta-db:5432/norish
DATABASE_URL=postgres://postgres:norish-beta@norish-beta-db:5432/norish

# NEW encryption key for beta — MUST differ from live's MASTER_KEY.
# Generate: openssl rand -base64 32
# WARNING: Do NOT copy the live key here. Beta secrets encrypted with live's key
#          are incompatible, and sharing keys leaks the live secret store.
MASTER_KEY=<REPLACE_WITH_NEW_BASE64_32_BYTE_KEY>

# Redis — points at the isolated norish-beta-redis container.
REDIS_URL=redis://norish-beta-redis:6379

# ── Camoufox scraping ─────────────────────────────────────────────────────────

# Reuse the shared Camoufox REST service (stateless, safe to share).
CAMOFOX_URL=http://192.168.2.26:9377
# CAMOFOX_API_KEY=  # Only needed for per-site cookie injection; leave unset unless required.

# ── Auth toggles ──────────────────────────────────────────────────────────────

PASSWORD_AUTH_ENABLED=false
ENABLE_REGISTRATION=true

# ── WorkOS AuthKit (beta callback registered at the WorkOS dashboard) ─────────
#
# Register https://norish-beta.knoppsmart.com/api/auth/oauth2/callback/workos
# in WorkOS dashboard → User Management → Redirects before activating.
WORKOS_CLIENT_ID=client_01KV3ADWK7MYAD4FBM0N14RCCC
WORKOS_API_KEY=<REPLACE_WITH_WORKOS_API_KEY>

# ── Locale ────────────────────────────────────────────────────────────────────

DEFAULT_LOCALE=nl
ENABLED_LOCALES=nl,en

# ── AI / Transcription (optional — inherit from live config or override) ───────

AI_ENABLED=true
# AI_PROVIDER=deepseek
# AI_MODEL=deepseek-chat
# AI_API_KEY=<your-ai-api-key>
# VIDEO_PARSING_ENABLED=true
# TRANSCRIPTION_PROVIDER=assemblyai
# TRANSCRIPTION_API_KEY=<your-transcription-api-key>
