{
  "name": "@norish/tailwind-config",
  "private": true,
  "type": "module",
  "exports": {
    "./heroui-theme": {
      "node": "./heroui-theme.js",
      "default": "./heroui-theme.css"
    },
    "./postcss-config": "./postcss-config.js"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/postcss": "catalog:",
    "postcss": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@norish/prettier-config": "workspace:*",
    "@norish/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@norish/prettier-config"
}
